source "https://rubygems.org"

# GitHub Pages 호환. 로컬 단독 빌드 시 jekyll 직접 사용도 가능.
gem "jekyll", "~> 4.3"
gem "minima", "~> 2.5"

group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.17"
  gem "jekyll-seo-tag", "~> 2.8"
  gem "jekyll-paginate", "~> 1.1"
end

# Windows/모던 Ruby 호환용
gem "webrick", "~> 1.8"
